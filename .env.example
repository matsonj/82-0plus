# ─────────────────────────────────────────────────────────────────────────────
# Postgres (PlanetScale) — the transactional tournament tables (OLTP)
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED. Connection string for the PlanetScale Postgres database that holds the
# transactional tables (users, teams, daily_results, ghosts, private_tournaments,
# private_entries). These moved off MotherDuck so the home-page point lookups stay
# fast (no serverless cold start). Use the POOLED endpoint — PlanetScale routes
# pooling by PORT: the app uses 6432 (PgBouncer) so serverless fan-out doesn't
# exhaust connections; the direct 5432 endpoint is for migrations/DDL/admin only.
# Any libpq ssl* query params (sslmode/sslrootcert=system) are stripped by
# lib/oltpDb.ts, which verifies TLS explicitly — the cert is publicly trusted.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.psdb.cloud:6432/DBNAME

# OPTIONAL dedicated READ-ONLY connection for the public read paths
# (/api/tournament/{bracket,team,lookup}, which read the auth + teams tables). Point
# it at a PlanetScale role with SELECT-only grants on the `tournament` schema — this
# keeps a leak of the public read connection away from the PIN auth table (smaller
# blast radius). If unset, those reads fall back to DATABASE_URL.
# DATABASE_URL_RO=

# Optional Postgres pool sizing (PlanetScale's pooler handles concurrency, so keep
# these small). Defaults: 5 each.
# OLTP_PG_POOL_MAX=5
# OLTP_PG_RO_POOL_MAX=5

# ─────────────────────────────────────────────────────────────────────────────
# MotherDuck — analytical data (OLAP): the NBA box scores + the app_cache rollups
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED. MotherDuck Read Scaling token — get one from https://app.motherduck.com
# (Settings → Access Tokens). The app queries `nba_box_scores_v2` (and the derived
# `app_cache`) at runtime via the PostgreSQL endpoint for the player index, rosters,
# scoring, etc.
MOTHERDUCK_TOKEN=

# MotherDuck Read-WRITE token — required to build the `app_cache` derived-data cache
# (the app CREATEs and refreshes the materialized game_quality / player_index /
# player-card rollups under this token, reading from `nba_box_scores_v2`). A
# read-scaling token cannot write. NOTE: the transactional tournament tables now
# live in Postgres (DATABASE_URL) — they are NOT written through this token anymore.
# Get one from app.motherduck.com (Settings → Access Tokens).
MOTHERDUCK_RW_TOKEN=

# Set to 1 to expose the per-game "WHY" modifier breakdown in the tournament
# bracket (a debug/tuning view). Unset/0 hides it in normal play. Must be
# NEXT_PUBLIC_ to reach the client; it's inlined at build time.
# NEXT_PUBLIC_DEBUG=1

# Server-only HMAC secret for signed roll receipts + daily share tokens.
# REQUIRED in production (the app throws if unset); dev/test use a fixed
# placeholder. NOT derived from any DB token. Rotating it invalidates outstanding
# roll receipts and daily share links.
# TOURNAMENT_SECRET=

# Optional MotherDuck Postgres endpoint overrides (used by the OLAP read pool and
# the app_cache RW pool).
# MOTHERDUCK_PG_HOST=pg.us-east-1-aws.motherduck.com
# MOTHERDUCK_PG_POOL_MAX=4
# MOTHERDUCK_PG_POOL_CACHE_MAX=32
