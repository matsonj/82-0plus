# MotherDuck Read Scaling token — get one from https://app.motherduck.com (Settings → Access Tokens)
# The app queries the `nba_box_scores_v2` database at runtime via the PostgreSQL endpoint.
MOTHERDUCK_TOKEN=

# MotherDuck Read-WRITE token — required ONLY for Tournament Edition (writes to the
# `nba_tournament` database via the same PostgreSQL endpoint). A read-scaling token
# cannot write. Get one from app.motherduck.com (Settings → Access Tokens).
MOTHERDUCK_RW_TOKEN=

# Dedicated READ-ONLY token for the public tournament read paths
# (/api/tournament/{bracket,team,lookup}, which read the auth + teams tables). Kept
# separate from MOTHERDUCK_TOKEN so a leak of the app-wide read token can't reach
# the PIN auth table, and from the RW token so this one can't write. Point it at a
# read-only token whose account has `nba_tournament` ATTACHed via a MotherDuck share
# (see README). REQUIRED in production; outside production it falls back to
# MOTHERDUCK_RW_TOKEN so local dev needn't provision a separate token + share.
# MOTHERDUCK_TOURNAMENT_RO_TOKEN=

# Set to 1 to expose the per-game "WHY" modifier breakdown in the tournament
# bracket (a debug/tuning view). Unset/0 hides it in normal play. Must be
# NEXT_PUBLIC_ to reach the client; it's inlined at build time.
# NEXT_PUBLIC_DEBUG=1

# Server-only HMAC secret for signed roll receipts + daily share tokens.
# REQUIRED in production (the app throws if unset); dev/test use a fixed
# placeholder. NOT derived from any DB token. Rotating it invalidates outstanding
# roll receipts and daily share links.
# TOURNAMENT_SECRET=

# Optional: database name the public read paths SELECT from on the READ token.
# Default `nba_tournament`. Set this if you expose the tournament tables to the
# read token via a MotherDuck share attached under a different alias.
# TOURNAMENT_RO_DB=nba_tournament

# Optional Postgres endpoint overrides.
# MOTHERDUCK_PG_HOST=pg.us-east-1-aws.motherduck.com
# MOTHERDUCK_PG_POOL_MAX=4
# MOTHERDUCK_PG_POOL_CACHE_MAX=32
